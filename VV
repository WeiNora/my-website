.member-hero .s-head{color:var(--cream);}
.member-hero p{color:rgba(253,248,241,0.6);max-width:480px;}

/* tier cards */
.tiers-wrap{padding:40px 24px 0;display:grid;grid-template-columns:repeat(3,1fr);gap:22px;}
.tier-card{border-radius:10px;overflow:hidden;border:2px solid rgba(122,78,45,0.15);box-shadow:3px 4px 0 rgba(122,78,45,0.1);transition:all .28s;}
.tier-card:hover{transform:translateY(-5px) rotate(-.3deg);box-shadow:6px 8px 0 rgba(122,78,45,0.16);}
.tier-top{padding:28px 24px 22px;text-align:center;}
.tier-badge{display:inline-block;font-family:'Caveat',cursive;font-size:13px;font-weight:700;padding:4px 14px;border-radius:20px;margin-bottom:10px;}
.tier-icon{font-size:44px;margin-bottom:8px;}
.tier-name{font-family:'Caveat',cursive;font-size:26px;font-weight:700;margin-bottom:4px;}
.tier-sub{font-family:'Noto Sans TC',sans-serif;font-size:11px;letter-spacing:.12em;opacity:.65;}
.tier-body{background:var(--cream);padding:22px 22px 28px;}
.tier-body ul{list-style:none;display:flex;flex-direction:column;gap:9px;}
.tier-body li{font-family:'Noto Serif TC',serif;font-size:13px;font-weight:300;color:var(--brown);display:flex;gap:8px;line-height:1.7;}
.tier-body li::before{content:'✓';color:var(--sage);font-weight:700;flex-shrink:0;}
.tier-cond{font-family:'Caveat',cursive;font-size:14px;color:var(--kraft);margin-top:14px;padding-top:14px;border-top:1px dashed rgba(122,78,45,0.2);}

/* points system */
.points-section{padding:48px 24px 60px;}
.points-section h3{font-family:'Caveat',cursive;font-size:28px;font-weight:700;color:var(--dark);margin-bottom:24px;}
.points-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:36px;}
.point-card{background:var(--sand);border:2px solid rgba(122,78,45,0.13);border-radius:8px;padding:20px 16px;text-align:center;box-shadow:2px 3px 0 rgba(122,78,45,0.07);}
.point-card .p-ico{font-size:28px;margin-bottom:8px;}
.point-card .p-num{font-family:'Caveat',cursive;font-size:28px;font-weight:700;color:var(--rust);}
.point-card .p-lbl{font-family:'Noto Serif TC',serif;font-size:12px;font-weight:300;color:var(--brown);line-height:1.7;margin-top:4px;}

/* CLV section */
.clv-section{background:var(--dark);padding:48px 24px;margin:0;}
.clv-inner{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center;}
.clv-text h3{font-family:'Caveat',cursive;font-size:28px;font-weight:700;color:var(--cream);margin-bottom:14px;}
.clv-text p{font-family:'Noto Serif TC',serif;font-size:13px;font-weight:300;line-height:2;color:rgba(253,248,241,0.58);margin-bottom:16px;}
.clv-badge{display:inline-block;background:rgba(201,168,122,0.15);border:1px solid rgba(201,168,122,0.3);
  color:var(--kraft);font-family:'Caveat',cursive;font-size:14px;padding:6px 16px;border-radius:20px;margin:4px;}
.clv-chart{background:rgba(253,248,241,0.05);border-radius:8px;padding:24px;border:1px solid rgba(201,168,122,0.15);}
.clv-chart h4{font-family:'Caveat',cursive;font-size:16px;color:var(--kraft);margin-bottom:16px;text-align:center;}
.bar-row{display:flex;align-items:center;gap:12px;margin-bottom:10px;}
.bar-label{font-family:'Caveat',cursive;font-size:14px;color:var(--cream);width:60px;flex-shrink:0;}
.bar-track{flex:1;height:20px;background:rgba(255,255,255,0.08);border-radius:10px;overflow:hidden;}
.bar-fill{height:100%;border-radius:10px;transition:width 1s ease;}
.bar-val{font-family:'Caveat',cursive;font-size:14px;color:var(--kraft);width:50px;text-align:right;flex-shrink:0;}

/* ── DATA DASHBOARD ── */
#view-data{background:var(--dark);}
.data-hero{padding:60px 24px 40px;position:relative;}
.data-hero .s-tag{color:var(--kraft);}
.data-hero .s-tag::before{background:var(--kraft);}
.data-hero .s-head{color:var(--cream);}
.data-hero p{color:rgba(253,248,241,0.55);max-width:520px;}
.dashboard{padding:0 24px 80px;display:grid;grid-template-columns:repeat(2,1fr);gap:20px;}
.dash-card{background:rgba(253,248,241,0.05);border:1px solid rgba(201,168,122,0.15);border-radius:10px;padding:28px 24px;}
.dash-card h3{font-family:'Caveat',cursive;font-size:18px;font-weight:700;color:var(--cream);margin-bottom:18px;
  display:flex;align-items:center;gap:8px;}
.kpi-row{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:8px;}
.kpi{background:rgba(255,255,255,0.06);border-radius:6px;padding:14px 12px;text-align:center;}
.kpi-num{font-family:'Caveat',cursive;font-size:28px;font-weight:700;color:var(--kraft);line-height:1;}
.kpi-lbl{font-family:'Noto Sans TC',sans-serif;font-size:10px;color:rgba(253,248,241,0.4);letter-spacing:.1em;margin-top:3px;}
.chart-area{margin-top:6px;}
.chart-bar-h{display:flex;align-items:center;gap:10px;margin-bottom:8px;}
.cbh-lbl{font-family:'Caveat',cursive;font-size:13px;color:rgba(253,248,241,0.6);width:55px;flex-shrink:0;text-align:right;}
.cbh-track{flex:1;height:18px;background:rgba(255,255,255,0.07);border-radius:9px;overflow:hidden;}
.cbh-fill{height:100%;border-radius:9px;}
.cbh-val{font-family:'Caveat',cursive;font-size:13px;color:var(--kraft);width:40px;flex-shrink:0;}
.data-note{font-family:'Noto Serif TC',serif;font-size:11px;color:rgba(253,248,241,0.3);margin-top:10px;font-weight:300;}

/* donut chart */
.donut-wrap{position:relative;width:130px;height:130px;margin:0 auto 14px;}
.donut-wrap canvas{display:block;}
.donut-center{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);text-align:center;}
.donut-center .dc-num{font-family:'Caveat',cursive;font-size:24px;font-weight:700;color:var(--kraft);}
.donut-center .dc-lbl{font-family:'Noto Sans TC',sans-serif;font-size:9px;color:rgba(253,248,241,0.4);letter-spacing:.1em;}
.legend{display:flex;flex-direction:column;gap:6px;}
