.nb-cta:hover{transform:translate(-1px,-1px);box-shadow:4px 5px 0 rgba(122,78,45,0.22);}
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;padding:6px;}
.hamburger span{width:22px;height:2px;background:var(--brown);border-radius:2px;display:block;}

