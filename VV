.f-submit{width:100%;padding:14px;background:var(--brown);color:var(--cream);font-family:'Caveat',cursive;font-size:19px;font-weight:700;
  border:none;border-radius:6px;cursor:pointer;box-shadow:3px 4px 0 rgba(58,36,18,0.17);margin-top:6px;transition:all .22s;}
.f-submit:hover{transform:translate(-2px,-2px);box-shadow:5px 6px 0 rgba(58,36,18,0.17);background:var(--dark);}
.f-note{font-family:'Caveat',cursive;font-size:14px;color:rgba(58,36,18,0.35);text-align:center;margin-top:9px;}
.f-ok{display:none;flex-direction:column;align-items:center;justify-content:center;text-align:center;gap:13px;min-height:380px;}
.f-ok.show{display:flex;}
.f-ok .ok-e{font-size:60px;}
.f-ok h3{font-family:'Caveat',cursive;font-size:26px;font-weight:700;color:var(--dark);}
.f-ok p{font-family:'Noto Serif TC',serif;font-size:14px;font-weight:300;line-height:2;color:var(--brown);}

/* ── FOOTER ── */
footer{background:var(--dark);padding:52px 0 30px;}
.footer-g{max-width:1140px;margin:0 auto;padding:0 24px;display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:38px;margin-bottom:44px;}
.fb-brand h3{font-family:'Caveat',cursive;font-size:24px;font-weight:700;color:var(--cream);margin-bottom:9px;}
.fb-brand h3 span{color:var(--kraft);}
.fb-brand p{font-family:'Noto Serif TC',serif;font-size:13px;font-weight:300;color:rgba(253,248,241,0.38);line-height:2;max-width:250px;}
.f-col h4{font-family:'Caveat',cursive;font-size:15px;font-weight:700;color:var(--kraft);margin-bottom:13px;}
.f-col ul{list-style:none;display:flex;flex-direction:column;gap:7px;}
.f-col li{font-family:'Noto Sans TC',sans-serif;font-size:12px;color:rgba(253,248,241,0.38);cursor:pointer;transition:color .2s;}
.f-col li:hover{color:var(--kraft);}
.footer-bot{max-width:1140px;margin:0 auto;padding:18px 24px 0;border-top:1px solid rgba(253,248,241,0.07);
  display:flex;align-items:center;justify-content:space-between;}
.footer-bot p{font-family:'Noto Sans TC',sans-serif;font-size:11px;color:rgba(253,248,241,0.23);text-align:center;}
.socials{display:flex;gap:16px;}
.socials a{font-family:'Caveat',cursive;font-size:14px;color:rgba(253,248,241,0.32);transition:color .2s;cursor:pointer;}
.socials a:hover{color:var(--kraft);}

/* ── AI CHATBOT ── */
#chatBtn{position:fixed;bottom:28px;right:28px;z-index:5000;
  width:56px;height:56px;border-radius:50%;background:var(--brown);border:none;cursor:pointer;
  font-size:24px;box-shadow:0 4px 20px rgba(58,36,18,0.3);transition:all .25s;display:flex;align-items:center;justify-content:center;}
#chatBtn:hover{transform:scale(1.1);background:var(--dark);}
.chat-bubble{position:absolute;bottom:66px;right:0;background:var(--dark);color:var(--cream);
  font-family:'Caveat',cursive;font-size:14px;padding:8px 14px;border-radius:12px 12px 0 12px;
  white-space:nowrap;opacity:0;transition:opacity .3s;pointer-events:none;}
#chatBtn:hover .chat-bubble{opacity:1;}

#chatBox{position:fixed;bottom:96px;right:28px;z-index:5000;
  width:320px;background:var(--cream);border-radius:12px;border:2px solid rgba(122,78,45,0.18);
  box-shadow:0 12px 48px rgba(58,36,18,0.2);display:none;flex-direction:column;overflow:hidden;}
#chatBox.open{display:flex;}
.chat-head{background:var(--brown);padding:14px 18px;display:flex;align-items:center;gap:10px;justify-content:space-between;}
.chat-head-l{display:flex;align-items:center;gap:10px;}
.chat-avatar{width:32px;height:32px;border-radius:50%;background:var(--kraft);display:flex;align-items:center;justify-content:center;font-size:16px;}
.chat-head h4{font-family:'Caveat',cursive;font-size:16px;font-weight:700;color:var(--cream);}
.chat-head p{font-size:10px;color:rgba(253,248,241,0.55);}
.chat-close{background:none;border:none;cursor:pointer;color:rgba(253,248,241,0.6);font-size:18px;transition:color .2s;}
.chat-close:hover{color:var(--cream);}
.chat-msgs{flex:1;max-height:260px;overflow-y:auto;padding:16px;display:flex;flex-direction:column;gap:10px;}
.chat-msgs::-webkit-scrollbar{width:3px;}
.chat-msgs::-webkit-scrollbar-thumb{background:rgba(122,78,45,0.2);border-radius:3px;}
.msg{max-width:85%;padding:10px 13px;border-radius:10px;font-family:'Noto Serif TC',serif;font-size:13px;font-weight:300;line-height:1.7;}
.msg.bot{background:var(--sand);color:var(--ink);border-radius:4px 10px 10px 10px;align-self:flex-start;}
.msg.user{background:var(--brown);color:var(--cream);border-radius:10px 4px 10px 10px;align-self:flex-end;}
.msg.typing{background:var(--sand);align-self:flex-start;border-radius:4px 10px 10px 10px;}
.typing-dots{display:flex;gap:4px;padding:2px 4px;}
.typing-dots span{width:6px;height:6px;border-radius:50%;background:var(--kraft);animation:dot .8s ease-in-out infinite;}
.typing-dots span:nth-child(2){animation-delay:.16s;}
.typing-dots span:nth-child(3){animation-delay:.32s;}
@keyframes dot{0%,80%,100%{transform:scale(0.6);opacity:.4}40%{transform:scale(1);opacity:1}}
.chat-quick{display:flex;gap:6px;padding:8px 14px;flex-wrap:wrap;border-top:1px solid rgba(122,78,45,0.1);}
.q-btn{font-family:'Caveat',cursive;font-size:13px;padding:5px 11px;border-radius:14px;
  border:1.5px solid rgba(122,78,45,0.22);background:transparent;color:var(--brown);cursor:pointer;transition:all .2s;}
.q-btn:hover{background:var(--brown);color:var(--cream);border-color:var(--brown);}
.chat-input-row{display:flex;gap:8px;padding:10px 14px;border-top:1px solid rgba(122,78,45,0.1);}
.chat-input{flex:1;border:1.5px solid rgba(122,78,45,0.18);border-radius:20px;padding:8px 14px;
  font-family:'Noto Serif TC',serif;font-size:13px;font-weight:300;color:var(--ink);background:var(--sand);outline:none;}
.chat-input:focus{border-color:var(--kraft);}
.chat-send{padding:8px 14px;background:var(--brown);color:var(--cream);border:none;border-radius:20px;
  cursor:pointer;font-family:'Caveat',cursive;font-size:14px;font-weight:700;transition:background .2s;}
.chat-send:hover{background:var(--dark);}

/* ── MOOD RECOMMENDER ── */
.mood-section{background:var(--warm);padding:56px 24px;}
.mood-section h3{font-family:'Caveat',cursive;font-size:28px;font-weight:700;color:var(--dark);margin-bottom:8px;}
.mood-section>p{font-family:'Noto Serif TC',serif;font-size:13px;font-weight:300;color:var(--brown);margin-bottom:24px;line-height:1.9;}
.mood-btns{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:24px;}
.mood-btn{font-family:'Caveat',cursive;font-size:17px;padding:10px 22px;border-radius:22px;
  border:2px solid rgba(122,78,45,0.2);background:var(--cream);color:var(--brown);cursor:pointer;transition:all .22s;
  box-shadow:2px 3px 0 rgba(122,78,45,0.08);}
.mood-btn:hover,.mood-btn.picked{background:var(--brown);color:var(--cream);border-color:var(--brown);
  transform:translate(-1px,-1px);box-shadow:3px 4px 0 rgba(58,36,18,0.15);}
.mood-result{display:none;background:var(--cream);border-radius:10px;border:2px solid var(--kraft);
  padding:24px;animation:pRev .4s both;}
.mood-result.show{display:block;}
.mood-result h4{font-family:'Caveat',cursive;font-size:22px;font-weight:700;color:var(--dark);margin-bottom:8px;}
.mood-result p{font-family:'Noto Serif TC',serif;font-size:13px;font-weight:300;line-height:1.9;color:var(--brown);}
.mood-result .mr-tag{display:inline-flex;gap:10px;align-items:center;margin-top:12px;
  background:var(--sand);padding:8px 16px;border-radius:6px;font-family:'Caveat',cursive;font-size:16px;color:var(--rust);}

/* ── SEARCH BAR ── */
.search-section { background: var(--cream); padding: 28px 24px 0; }
.search-wrap { display: flex; gap: 12px; align-items: center; background: var(--sand); border: 2px solid rgba(122,78,45,0.18); border-radius: 50px; padding: 10px 18px 10px 24px; transition: border-color .25s, box-shadow .25s; max-width: 680px; width: 100%; }
.search-wrap:focus-within { border-color: var(--kraft); box-shadow: 0 4px 20px rgba(122,78,45,0.12); }
.search-icon { font-size: 18px; flex-shrink: 0; opacity: .55; }
.search-input { flex: 1; border: none; background: transparent; font-family: 'Noto Serif TC', serif; font-size: 14px; font-weight: 300; color: var(--ink); outline: none; width: 100%; }
.search-input::placeholder { color: rgba(122,78,45,0.35); }
.search-btn { font-family: 'Caveat', cursive; font-size: 16px; font-weight: 700; padding: 8px 22px; background: var(--brown); color: var(--cream); border: none; border-radius: 30px; cursor: pointer; transition: all .22s; flex-shrink: 0; }
.search-btn:hover { background: var(--dark); transform: scale(1.04); }
.search-tags { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 12px; padding-bottom: 20px; }
.search-tag { font-family: 'Caveat', cursive; font-size: 14px; padding: 4px 14px; border-radius: 20px; border: 1.5px solid rgba(122,78,45,0.2); background: transparent; color: var(--brown); cursor: pointer; transition: all .18s; }
.search-tag:hover { background: var(--brown); color: var(--cream); border-color: var(--brown); }

/* ── REGION FILTER ── */
.region-section { background: var(--cream); padding: 16px 24px 0; display: flex; align-items: center; gap: 14px; flex-wrap: wrap; }
.region-label { font-family: 'Caveat', cursive; font-size: 15px; font-weight: 700; color: var(--brown); display: flex; align-items: center; gap: 6px; flex-shrink: 0; }
.region-pills { display: flex; gap: 8px; flex-wrap: wrap; }
.region-pill { font-family: 'Caveat', cursive; font-size: 15px; padding: 6px 16px; border-radius: 20px; border: 1.5px solid rgba(122,78,45,0.18); background: var(--sand); color: var(--brown); cursor: pointer; transition: all .2s; white-space: nowrap; }
.region-pill:hover { border-color: var(--kraft); }
.region-pill.on { background: var(--rust); color: var(--cream); border-color: var(--rust); box-shadow: 2px 3px 0 rgba(192,90,53,0.2); }

/* ── SEARCH RESULTS HEADER ── */
.result-header { padding: 14px 24px 0; background: var(--cream); display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 8px; }
.result-count { font-family: 'Caveat', cursive; font-size: 16px; color: var(--brown); }
.result-count span { color: var(--rust); font-weight: 700; font-size: 20px; }
.no-results { display: none; text-align: center; padding: 48px 24px; grid-column: 1/-1; }
.no-results .nr-icon { font-size: 48px; margin-bottom: 12px; }
.no-results h4 { font-family:'Caveat',cursive; font-size:22px; color:var(--dark); margin-bottom:8px; }
.no-results p { font-family:'Noto Serif TC',serif; font-size:13px; font-weight:300; color:var(--brown); }

.nb-member-btn{font-family:'Caveat',cursive;font-size:16px;font-weight:700;padding:8px 18px;
  background:transparent;color:var(--brown);border:2px solid rgba(122,78,45,0.3);border-radius:20px;
  cursor:pointer;transition:all .22s;margin-left:8px;}
.nb-member-btn:hover{background:var(--brown);color:var(--cream);border-color:var(--brown);}
.nb-member-btn.logged{background:var(--sage);color:white;border-color:var(--sage);}

/* ── AUTH MODAL ── */
#authOverlay{position:fixed;inset:0;background:rgba(46,31,15,0.6);z-index:9000;
  display:none;align-items:center;justify-content:center;backdrop-filter:blur(6px);padding:20px;}
#authOverlay.open{display:flex;}
.auth-box{background:var(--cream);border-radius:12px;width:min(440px,100%);overflow:hidden;
  box-shadow:0 24px 80px rgba(46,31,15,0.3);animation:pRev .35s both;}
.auth-tabs{display:flex;border-bottom:2px solid rgba(122,78,45,0.12);}
.auth-tab{flex:1;font-family:'Caveat',cursive;font-size:19px;font-weight:700;padding:16px;
  background:transparent;border:none;color:rgba(122,78,45,0.45);cursor:pointer;transition:all .2s;}
.auth-tab.on{color:var(--brown);border-bottom:3px solid var(--rust);margin-bottom:-2px;}
.auth-body{padding:24px; max-height:80vh; overflow-y:auto;}
.auth-body h3{font-family:'Caveat',cursive;font-size:24px;font-weight:700;color:var(--dark);margin-bottom:6px;}
.auth-body .auth-sub{font-family:'Noto Serif TC',serif;font-size:13px;font-weight:300;color:var(--brown);margin-bottom:24px;line-height:1.7;}
.auth-fg{display:flex;flex-direction:column;gap:5px;margin-bottom:14px;}
.auth-fg label{font-family:'Caveat',cursive;font-size:15px;font-weight:700;color:var(--brown);}
.auth-fg input{background:var(--sand);border:2px solid rgba(122,78,45,0.18);border-radius:6px;
  padding:11px 14px;font-family:'Noto Serif TC',serif;font-size:13px;font-weight:300;color:var(--dark);
  outline:none;transition:border-color .2s;width:100%;}
.auth-fg input:focus{border-color:var(--kraft);}
.auth-fg-2{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.auth-submit{width:100%;padding:13px;background:var(--brown);color:var(--cream);font-family:'Caveat',cursive;
  font-size:19px;font-weight:700;border:none;border-radius:6px;cursor:pointer;margin-top:6px;
  box-shadow:3px 4px 0 rgba(58,36,18,0.17);transition:all .22s;}
.auth-submit:hover{background:var(--dark);transform:translate(-1px,-1px);}
.auth-err{font-family:'Caveat',cursive;font-size:14px;color:var(--rust);text-align:center;
  margin-top:8px;min-height:20px;}
.auth-close-row{text-align:right;padding:8px 16px 0;}
.auth-close-btn{background:none;border:none;font-size:20px;cursor:pointer;color:var(--brown);opacity:.5;transition:opacity .2s;}
.auth-close-btn:hover{opacity:1;}

/* ── MEMBER DASHBOARD MODAL ── */
#dashOverlay{position:fixed;inset:0;background:rgba(46,31,15,0.6);z-index:9000;
  display:none;align-items:center;justify-content:center;backdrop-filter:blur(6px);padding:20px;}
#dashOverlay.open{display:flex;}
.dash-box{background:var(--cream);border-radius:12px;width:min(520px,100%);max-height:85vh;overflow-y:auto;
