.fg input,.fg select,.fg textarea{background:var(--sand);border:2px solid rgba(122,78,45,0.18);border-radius:6px;
  padding:11px 13px;font-family:'Noto Serif TC',serif;font-size:13px;font-weight:300;color:var(--dark);outline:none;width:100%;
