.legend-pct{font-family:'Caveat',cursive;font-size:14px;color:var(--kraft);margin-left:auto;}

/* ════════════════ BOOKING ════════════════ */
.booking-layout{display:grid;grid-template-columns:340px 1fr;min-height:calc(100vh - 62px);}
.bk-left{background:var(--dark);padding:58px 24px;display:flex;flex-direction:column;justify-content:center;
  position:sticky;top:62px;height:calc(100vh - 62px);overflow:hidden;}
.bk-left::before{content:'';position:absolute;bottom:-80px;right:-80px;width:250px;height:250px;
  border-radius:50%;border:2px dashed rgba(201,168,122,0.1);}
.bk-left h2{font-family:'Caveat',cursive;font-size:clamp(28px,3.8vw,46px);font-weight:700;color:var(--cream);line-height:1.1;margin-bottom:15px;position:relative;z-index:1;}
.bk-left h2 em{color:var(--kraft);font-style:normal;}
.bk-left>p{font-family:'Noto Serif TC',serif;font-size:13px;font-weight:300;color:rgba(253,248,241,0.55);line-height:2;margin-bottom:28px;position:relative;z-index:1;}
.bk-info{display:flex;flex-direction:column;gap:14px;position:relative;z-index:1;}
