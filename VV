.t-item{display:flex;gap:22px;padding-bottom:28px;}
.t-item:last-child{padding-bottom:0;}
.t-dot{width:55px;height:55px;border-radius:50%;background:var(--cream);border:2.5px solid var(--kraft);
  display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0;position:relative;z-index:1;
  box-shadow:2px 3px 0 rgba(122,78,45,0.12);transition:all .25s;}
