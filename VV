.bk-h{font-family:'Caveat',cursive;font-size:14px;font-weight:700;color:var(--kraft);margin-bottom:2px;}
.bk-v{font-family:'Noto Sans TC',sans-serif;font-size:12px;color:rgba(253,248,241,0.42);line-height:1.75;}
