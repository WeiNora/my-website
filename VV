.pts-big{font-family:'Caveat',cursive;font-size:44px;font-weight:700;color:var(--rust);line-height:1;}
.pts-lbl{font-family:'Noto Serif TC',serif;font-size:12px;font-weight:300;color:var(--brown);}
.pts-next{font-family:'Caveat',cursive;font-size:20px;font-weight:700;color:var(--kraft);}

.progress-label{font-family:'Caveat',cursive;font-size:14px;color:var(--brown);margin-bottom:6px;display:flex;justify-content:space-between;}
.progress-track{height:12px;background:rgba(122,78,45,0.12);border-radius:6px;overflow:hidden;margin-bottom:20px;}
.progress-fill{height:100%;border-radius:6px;background:linear-gradient(to right,var(--kraft),var(--rust));transition:width .8s ease;}

