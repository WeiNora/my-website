.dash-close:hover{background:rgba(255,255,255,0.28);}
.dash-content{padding:24px;}

/* tier badge in dash */
.tier-pill{display:inline-flex;align-items:center;gap:8px;padding:8px 18px;border-radius:24px;
  font-family:'Caveat',cursive;font-size:16px;font-weight:700;margin-bottom:20px;box-shadow:2px 3px 0 rgba(58,36,18,0.12);}
.tier-espresso{background:linear-gradient(135deg,#e8c99a,#c9a87a);color:var(--dark);}
.tier-latte{background:linear-gradient(135deg,#d4938a,#a85a52);color:#fff;}
.tier-pourover{background:linear-gradient(135deg,#c9a030,#8c6e10);color:#fff;}

.pts-row{display:flex;align-items:center;justify-content:space-between;
