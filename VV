  border-radius:50%;border:2px dashed rgba(201,168,122,0.17);}
.about-left h2{font-family:'Caveat',cursive;font-size:clamp(32px,3.8vw,50px);font-weight:700;color:var(--cream);line-height:1.1;margin-bottom:16px;position:relative;z-index:1;}
.about-left h2 em{color:var(--kraft);font-style:normal;}
.about-left p{font-family:'Noto Serif TC',serif;font-size:13px;font-weight:300;line-height:2;color:rgba(253,248,241,0.58);position:relative;z-index:1;margin-bottom:12px;}
